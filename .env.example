# ====================================
# TRIVARO PROP FIRM - ROOT ENVIRONMENT VARIABLES
# ====================================

# Application
NODE_ENV=development
APP_NAME=Trivaro Prop Firm
VERSION=1.0.0

# Backend
BACKEND_PORT=5000
BACKEND_URL=http://localhost:5000

# Frontend
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/trivaro

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Encryption
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# MetaAPI
META_API_TOKEN=your-metaapi-token-here
DOPRIME_SERVER_NAME=Doprime-Server

# Email
EMAIL_SERVICE=sendgrid
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@trivaro.com

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=trivaro-documents
